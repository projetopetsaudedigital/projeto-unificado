# Copie este arquivo para .env e preencha com suas credenciais.
# O arquivo .env NUNCA deve ser commitado no git.

# Ambiente
ENVIRONMENT=development

# ── Modo de banco de dados ────────────────────────────────────────────
# "fdw"    → dois bancos: pet_saude (leitura) + admin-esus (views/controle)
#            Requer setup_fdw.sql executado no admin-esus previamente.
# "single" → tudo em pet_saude, sem FDW. Mais simples e mais rápido.
#            Preencha apenas as variáveis DB_* abaixo.
DB_MODE=single

# ── Banco PEC (pet_saude) — usado em ambos os modos ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pet_saude
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ── Banco Admin (admin-esus) — apenas para DB_MODE=fdw ──
ADMIN_DB_HOST=localhost
ADMIN_DB_PORT=5432
ADMIN_DB_NAME=admin-esus
ADMIN_DB_USER=postgres
ADMIN_DB_PASSWORD=sua_senha_aqui

# CORS (separar múltiplos por vírgula se necessário via código)
# As origens padrão já incluem localhost:3000 e localhost:5173 (Vite)

# Qualidade de dados
OUTLIER_ZSCORE_THRESHOLD=3.0
OUTLIER_IQR_FACTOR=1.5

# Validação de PA
PA_PAS_MIN=50
PA_PAS_MAX=300
PA_PAD_MIN=30
PA_PAD_MAX=200

# JWT Auth
# IMPORTANTE: troque em produção! Gere com: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE-ME-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
